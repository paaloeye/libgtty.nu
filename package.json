{
  "name": "libgtty-nu",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "fmt": "bun fmt:swift && bun run fmt:docs",
    "fmt:swift": "xcrun swift-format format --in-place",
    "fmt:docs": "prettier --write --ignore-unknown",
    "fmt:docs:check": "prettier --check ."
  },
  "devDependencies": {
    "prettier": "^3.3.3"
  }
}
